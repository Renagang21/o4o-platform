# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000/api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=o4o_platform
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-2
AWS_BUCKET_NAME=your_bucket_name

# Payment (예: 토스페이먼츠)
PAYMENT_API_KEY=your_payment_api_key
PAYMENT_SECRET_KEY=your_payment_secret_key

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Medusa
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_API_KEY=your_admin_api_key

# Digital Signage
SIGNAGE_DEVICE_TOKEN=your_device_token
SIGNAGE_API_ENDPOINT=http://localhost:4000/api/signage

# LMS
LMS_STORAGE_PATH=/path/to/lms/storage
LMS_VIDEO_PROVIDER=your_video_provider
LMS_VIDEO_API_KEY=your_video_api_key

# Monitoring
SENTRY_DSN=your_sentry_dsn
NEW_RELIC_LICENSE_KEY=your_newrelic_key

# Feature Flags
ENABLE_MARKETPLACE=true
ENABLE_CROWDFUNDING=true
ENABLE_DIGITAL_SIGNAGE=true
ENABLE_LMS=true 