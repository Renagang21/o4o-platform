# Temp/debug files
tmp-*
test123.txt
nul

# Playwright E2E test artifacts (generated output, not source)
test-results/
playwright-report/
*-after-event.png

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-temporary-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Vite-specific files
.vite/
dist/

# TypeScript build cache
*.tsbuildinfo

# Build metadata
**/version.json

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.local
.env.development
.env.production
.env-apiserver

# Allow example env files
!.env*.example

# parcel-bundler cache (https://parceljs.org/)
.cache

# Next.js build output
.next
out

# Nuxt.js build output
.nuxt

# Storybook build output
storybook-static

# Temporary files
.tmp

# Backups
*.backup
*.bak

# IDE-specific files
.idea/
.vscode/
.claude/

# OS-specific files
.DS_Store
Thumbs.db
apps/admin-dashboard/.vite-cache/

# Cloud SQL Proxy
bin/cloud-sql-proxy.exe
bin/cloud_sql_proxy

# Playwright MCP screenshots
.playwright-mcp/

# Per-machine MCP server config (paths/commands differ by host)
.mcp.json

# Local test accounts (browser verification — never commit)
docs/local/*.local.md

# Verification script outputs (screenshots, findings JSON — reproducible by re-running the script)
scripts/verify/output/

# Vite config build artifacts — source is vite.config.ts (services/web-* 는 .ts 만 추적)
services/web-*/vite.config.js
services/web-*/vite.config.d.ts
