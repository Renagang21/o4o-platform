{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@o4o/ui": ["../../packages/ui"],
      "@o4o/ui/*": ["../../packages/ui/*"],
      "@o4o/lib": ["../../packages/lib"],
      "@o4o/lib/*": ["../../packages/lib/*"],
      "@o4o/types": ["../../packages/types"],
      "@o4o/types/*": ["../../packages/types/*"],
      "@o4o/config": ["../../packages/config"],
      "@o4o/config/*": ["../../packages/config/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src/components/editor"]
}