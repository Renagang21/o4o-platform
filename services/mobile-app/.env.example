# O4O Mobile App 환경변수 예시
# 실제 값은 .env.local 에 복사 후 설정
# Expo 공개 환경변수는 EXPO_PUBLIC_ prefix 필수

# API 서버 베이스 URL
EXPO_PUBLIC_API_BASE_URL=https://o4o-core-api-117791934476.asia-northeast3.run.app

# 개발 시 로컬 API 서버 사용 시:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000  (Android Emulator → localhost)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3000  (실기기 → PC IP)
