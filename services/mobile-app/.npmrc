# mobile-app 전용 pnpm 설정
# WO-O4O-MOBILE-EXPO-DEPENDENCY-STABILIZATION-V1

# root .npmrc 의 prefer-offline=true 를 override.
# Why: lockfile 에 pin 된 @babel/parser@7.29.3 등 신규 패치 버전을 pnpm 이
# stale metadata cache(예: 7.29.0 이 최신으로 캐시됨) 때문에 ERR_PNPM_NO_MATCHING_VERSION 으로
# 실패시키는 문제 회피. react-native@0.79.6 → @react-native/codegen 설치 경로에서 재현됨.
prefer-offline=false
